(수정)
class SharedState:
  def__int__(self):
    self.__processed_count = 0     # __를 붙여 외부수정을 막음
  def increment_count(self):  # 정해진 창구를 통해서만 숫자를 올림
    self.__processed_count += 1
  def get_count(self):
    return self.__processed_count  

